{
  "sceneId": "ch1_scene01",
  "title": "偶遇",
  "background": "assets/backgrounds/cafe_afternoon.jpg",
  "bgm": "assets/bgm/warm_afternoon.mp3",
  "initialCharacter": "kai",
  "initialEmotion": "neutral",
  "lines": [

    {
      "id": "s01_intro",
      "type": "narration",
      "text": "深秋的午后，阳光从玻璃窗斜切进来，把咖啡馆的木桌照得有点亮。\n你刚点了咖啡，找了个靠窗的位子，正翻开手里的书。",
      "next": "s01_door"
    },

    {
      "id": "s01_door",
      "type": "narration",
      "text": "门口传来一点动静。你没有抬头。",
      "next": "s01_kai_enter"
    },

    {
      "id": "s01_kai_enter",
      "type": "character_enter",
      "character": "kai",
      "emotion": "neutral",
      "animation": "slide_in_right",
      "next": "s01_kai_notice"
    },

    {
      "id": "s01_kai_notice",
      "type": "narration",
      "text": "是凯恒。\n你认出他的时候，他也认出了你。",
      "next": "s01_kai_l1"
    },

    {
      "id": "s01_kai_l1",
      "type": "dialogue",
      "speaker": "kai",
      "emotion": "neutral",
      "text": "……这里。"
    },
    {
      "id": "s01_kai_l1b",
      "type": "dialogue",
      "speaker": "kai",
      "emotion": "neutral",
      "text": "咖啡馆满了。可以坐对面吗。",
      "next": "s01_player_choice1"
    },

    {
      "id": "s01_player_choice1",
      "type": "choice",
      "prompt": null,
      "options": [
        {
          "id": "A",
          "text": "当然，请坐。",
          "affectionDelta": 5,
          "emotion": "friendly",
          "next": "s01_sit_a"
        },
        {
          "id": "B",
          "text": "好久不见。",
          "affectionDelta": 8,
          "emotion": "warm",
          "next": "s01_sit_b"
        },
        {
          "id": "C",
          "text": "随便。",
          "affectionDelta": 0,
          "emotion": "neutral",
          "next": "s01_sit_c"
        }
      ]
    },

    {
      "id": "s01_sit_a",
      "type": "dialogue",
      "speaker": "kai",
      "emotion": "neutral",
      "text": "……谢。",
      "next": "s01_order"
    },
    {
      "id": "s01_sit_b",
      "type": "dialogue",
      "speaker": "kai",
      "emotion": "attentive",
      "text": "……嗯。好久不见。",
      "next": "s01_order"
    },
    {
      "id": "s01_sit_c",
      "type": "dialogue",
      "speaker": "kai",
      "emotion": "neutral",
      "text": "……",
      "next": "s01_order"
    },

    {
      "id": "s01_order",
      "type": "narration",
      "text": "他在对面坐下，叫了服务员，要了黑咖啡，没加糖。\n你们之间沉默了一会儿。不算太尴尬。",
      "next": "s01_kai_look"
    },

    {
      "id": "s01_kai_look",
      "type": "dialogue",
      "speaker": "kai",
      "emotion": "attentive",
      "text": "在看什么书。"
    },
    {
      "id": "s01_kai_look_b",
      "type": "narration",
      "text": "他的视线落在你手边的书封上，等你回答。",
      "next": "s01_player_choice2"
    },

    {
      "id": "s01_player_choice2",
      "type": "choice",
      "prompt": null,
      "options": [
        {
          "id": "A",
          "text": "建筑方面的，借来的。",
          "affectionDelta": 10,
          "next": "s01_book_a"
        },
        {
          "id": "B",
          "text": "小说，不太好看。",
          "affectionDelta": 5,
          "next": "s01_book_b"
        },
        {
          "id": "C",
          "text": "其实没怎么看进去，只是在发呆。",
          "affectionDelta": 4,
          "next": "s01_book_ai"
        }
      ]
    },

    {
      "id": "s01_book_a",
      "type": "dialogue",
      "speaker": "kai",
      "emotion": "caught",
      "text": "……"
    },
    {
      "id": "s01_book_a2",
      "type": "dialogue",
      "speaker": "kai",
      "emotion": "slight_smile",
      "text": "哪本。",
      "next": "s01_book_a3"
    },
    {
      "id": "s01_book_a3",
      "type": "narration",
      "text": "你翻给他看封面。他扫了一眼，沉默了几秒。",
      "next": "s01_book_a4"
    },
    {
      "id": "s01_book_a4",
      "type": "dialogue",
      "speaker": "kai",
      "emotion": "neutral",
      "text": "那本书有个地方写错了。第三章的案例，数据对不上。",
      "next": "s01_book_a5"
    },
    {
      "id": "s01_book_a5",
      "type": "dialogue",
      "speaker": "kai",
      "emotion": "neutral",
      "text": "……有兴趣的话，等你翻到那里，可以告诉你哪里。",
      "next": "s01_continue"
    },

    {
      "id": "s01_book_b",
      "type": "dialogue",
      "speaker": "kai",
      "emotion": "neutral",
      "text": "那就放下来。",
      "next": "s01_book_b2"
    },
    {
      "id": "s01_book_b2",
      "type": "narration",
      "text": "你没想到他会这么说。他的眼神没有开玩笑的意思。",
      "next": "s01_continue"
    },

    {
      "id": "s01_book_ai",
      "type": "dialogue",
      "speaker": "kai",
      "emotion": "attentive",
      "text": "……发呆也算是在看。至少比硬看下去好。",
      "next": "s01_continue"
    },

    {
      "id": "s01_continue",
      "type": "narration",
      "text": "咖啡送来了。他的黑咖啡，你的那杯，各自放在桌子两端。\n窗外的梧桐树在风里动了一下，叶子掉了几片。",
      "next": "s01_kai_question"
    },

    {
      "id": "s01_kai_question",
      "type": "dialogue",
      "speaker": "kai",
      "emotion": "neutral",
      "text": "最近……还好吗。",
      "next": "s01_kai_question2"
    },
    {
      "id": "s01_kai_question2",
      "type": "narration",
      "text": "他问这话的时候没有看你，在用手指转着咖啡杯。\n这个问题比他平时说的话要长一点。",
      "next": "s01_player_choice3",
      "image": {
        "path": "assets/cg/ch1/s01_kai_finger_cup.png",
        "status": "pending",
        "prompt": "男主修长手指轻转白瓷咖啡杯特写，木桌纹理，午后斜光从左侧打来，景深虚化背景，暖色调，电影感",
        "description": "凯恒紧张/思考时的小动作特写。在玩家选择回应他「最近还好吗」之前显示 1 拍，强化「观察」技能的伏笔。"
      }
    },

    {
      "id": "s01_player_choice3",
      "type": "choice",
      "prompt": null,
      "options": [
        {
          "id": "A",
          "text": "你今天好像有什么心事。",
          "label": "[观察]",
          "affectionDelta": 8,
          "skillUsed": { "id": "observe", "expGain": 2 },
          "next": "s01_observe_path"
        },
        {
          "id": "B",
          "text": "你为什么突然问这个？",
          "label": "[直球]",
          "affectionDelta": 8,
          "skillUsed": { "id": "direct", "expGain": 2 },
          "next": "s01_wellbeing_b"
        },
        {
          "id": "C",
          "text": "还行，就是有点累。",
          "affectionDelta": 5,
          "skillUsed": { "id": "empathy", "expGain": 1 },
          "next": "s01_wellbeing_a"
        },
        {
          "id": "D",
          "text": "不太好，但也说不上哪里不好。",
          "affectionDelta": 6,
          "skillUsed": { "id": "empathy", "expGain": 1 },
          "next": "s01_wellbeing_ai"
        },
        {
          "id": "E",
          "text": "你的手指在抖。",
          "label": "[观察]",
          "affectionDelta": 10,
          "skillUsed": { "id": "observe", "expGain": 3 },
          "requiredSkill": { "id": "observe", "level": 1 },
          "next": "s01_observe_extra"
        }
      ]
    },

    {
      "id": "s01_observe_path",
      "type": "dialogue",
      "speaker": "kai",
      "emotion": "caught",
      "text": "……"
    },
    {
      "id": "s01_observe_path2",
      "type": "narration",
      "text": "他的视线落在你脸上，停了半秒。\n手里转杯子的动作停了一下，又继续。",
      "next": "s01_observe_path3"
    },
    {
      "id": "s01_observe_path3",
      "type": "dialogue",
      "speaker": "kai",
      "emotion": "neutral",
      "text": "……没有。",
      "next": "s01_observe_path4"
    },
    {
      "id": "s01_observe_path4",
      "type": "skill_toast",
      "skill": "observe",
      "text": "你看见了他没说出来的那一秒。",
      "next": "s01_end_scene_transition"
    },

    {
      "id": "s01_observe_extra",
      "type": "narration",
      "text": "你说出口之后，他的手才停下来。\n不是装作没听见，是真的停下来了。",
      "next": "s01_kai_truth_a",
      "image": {
        "path": "assets/cg/ch1/s01_kai_hand_stop.png",
        "status": "pending",
        "prompt": "男主握咖啡杯的手在桌面上停住的特写，指节微微用力，杯沿与桌面之间的窄阴影，暖色调，景深虚化背景，电影感",
        "description": "[观察] Lv1 解锁选项「你的手指在抖」触发的特写。强化玩家「真的看见了」的瞬间。"
      }
    },
    {
      "id": "s01_kai_truth_a",
      "type": "dialogue",
      "speaker": "kai",
      "emotion": "caught",
      "text": "……上周做了个项目，结果不太好。"
    },
    {
      "id": "s01_kai_truth_a2",
      "type": "dialogue",
      "speaker": "kai",
      "emotion": "distant",
      "text": "我以为掩饰得还行。",
      "next": "s01_kai_truth_a3"
    },
    {
      "id": "s01_kai_truth_a3",
      "type": "skill_toast",
      "skill": "observe",
      "text": "他第一次没把话咽回去。",
      "next": "s01_end_scene_transition"
    },

    {
      "id": "s01_wellbeing_a",
      "type": "dialogue",
      "speaker": "kai",
      "emotion": "neutral",
      "text": "……嗯。",
      "next": "s01_wellbeing_a2"
    },
    {
      "id": "s01_wellbeing_a2",
      "type": "narration",
      "text": "他没有再说。但他的手停在了杯子上。",
      "next": "s01_end_scene_transition"
    },

    {
      "id": "s01_wellbeing_b",
      "type": "dialogue",
      "speaker": "kai",
      "emotion": "caught",
      "text": "……没有为什么。"
    },
    {
      "id": "s01_wellbeing_b2",
      "type": "dialogue",
      "speaker": "kai",
      "emotion": "neutral",
      "text": "随口问的。",
      "next": "s01_wellbeing_b3"
    },
    {
      "id": "s01_wellbeing_b3",
      "type": "narration",
      "text": "你不太相信。他不是会「随口问」任何事的人。",
      "next": "s01_end_scene_transition"
    },

    {
      "id": "s01_wellbeing_ai",
      "type": "dialogue",
      "speaker": "kai",
      "emotion": "attentive",
      "text": "……那就先别说哪里不好。坐一会儿。",
      "next": "s01_end_scene_transition"
    },

    {
      "id": "s01_end_scene_transition",
      "type": "narration",
      "text": "窗外的光渐渐暖了起来，下午两点变成了快三点。\n你们没有一直说话，但也没有离开的意思。",
      "next": "ch1_scene02"
    }
  ]
}
