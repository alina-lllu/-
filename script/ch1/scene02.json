{
  "sceneId": "ch1_scene02",
  "title": "雨",
  "background": "assets/backgrounds/cafe_rain.jpg",
  "bgm": "assets/bgm/rain_outside.mp3",
  "notes": "背景换成雨景版本：同一家咖啡馆，窗外开始有雨，光线变暗。BGM 加入雨声。",
  "lines": [

    {
      "id": "s02_rain_start",
      "type": "narration",
      "text": "就在你们都开始收拾东西、准备离开的时候，窗外突然下起雨来。\n不是小雨，是那种让人不得不等一等的雨。",
      "next": "s02_kai_rain"
    },

    {
      "id": "s02_kai_rain",
      "type": "dialogue",
      "speaker": "kai",
      "emotion": "neutral",
      "text": "……下雨了。"
    },
    {
      "id": "s02_kai_rain2",
      "type": "dialogue",
      "speaker": "kai",
      "emotion": "neutral",
      "text": "等一下吧。",
      "next": "s02_settle_back"
    },

    {
      "id": "s02_settle_back",
      "type": "narration",
      "text": "你们重新坐下。服务员过来问要不要续杯，你们都要了。\n这次没有借口说要走了。",
      "next": "s02_kai_work"
    },

    {
      "id": "s02_kai_work",
      "type": "dialogue",
      "speaker": "kai",
      "emotion": "neutral",
      "text": "……你在做什么工作。"
    },
    {
      "id": "s02_kai_work2",
      "type": "narration",
      "text": "他把咖啡杯搁在一边，第一次在这个下午真正看着你等答案。",
      "next": "s02_player_work"
    },

    {
      "id": "s02_player_work",
      "type": "choice",
      "prompt": null,
      "options": [
        {
          "id": "A",
          "text": "设计相关的，你大概不感兴趣。",
          "affectionDelta": 5,
          "next": "s02_work_a"
        },
        {
          "id": "B",
          "text": "跟你完全不同的行业。",
          "affectionDelta": 3,
          "next": "s02_work_b"
        },
        {
          "id": "C",
          "text": "做一些需要反复改来改去的事。",
          "affectionDelta": 5,
          "next": "s02_work_ai"
        }
      ]
    },

    {
      "id": "s02_work_a",
      "type": "dialogue",
      "speaker": "kai",
      "emotion": "slight_smile",
      "text": "……为什么觉得我不感兴趣。"
    },
    {
      "id": "s02_work_a2",
      "type": "dialogue",
      "speaker": "kai",
      "emotion": "attentive",
      "text": "说说看。",
      "next": "s02_work_continue"
    },

    {
      "id": "s02_work_b",
      "type": "dialogue",
      "speaker": "kai",
      "emotion": "neutral",
      "text": "……不同行业。"
    },
    {
      "id": "s02_work_b2",
      "type": "dialogue",
      "speaker": "kai",
      "emotion": "neutral",
      "text": "什么行业。",
      "next": "s02_work_continue"
    },

    {
      "id": "s02_work_ai",
      "type": "dialogue",
      "speaker": "kai",
      "emotion": "attentive",
      "text": "……反复改，说明你在乎结果。最难的部分是什么。",
      "next": "s02_work_continue"
    },

    {
      "id": "s02_work_continue",
      "type": "narration",
      "text": "你们说了一会儿工作的事。\n他问的问题都很具体，不是那种\"工作辛苦吗\"的废话。",
      "next": "s02_kai_share"
    },

    {
      "id": "s02_kai_share",
      "type": "dialogue",
      "speaker": "kai",
      "emotion": "neutral",
      "text": "……最近在做一个改造项目。老旧小区的公共空间。"
    },
    {
      "id": "s02_kai_share2",
      "type": "dialogue",
      "speaker": "kai",
      "emotion": "distant",
      "text": "居民们想要的东西，跟甲方想要的东西，不一样。"
    },
    {
      "id": "s02_kai_share3",
      "type": "dialogue",
      "speaker": "kai",
      "emotion": "neutral",
      "text": "……挺难的。",
      "next": "s02_player_respond_kai"
    },

    {
      "id": "s02_player_respond_kai",
      "type": "choice",
      "prompt": null,
      "options": [
        {
          "id": "A",
          "text": "听起来很消耗人。",
          "label": "[共情]",
          "affectionDelta": 10,
          "skillUsed": { "id": "empathy", "expGain": 2 },
          "next": "s02_respond_b"
        },
        {
          "id": "B",
          "text": "那你站哪边？",
          "label": "[追问]",
          "affectionDelta": 8,
          "skillUsed": { "id": "probe", "expGain": 2 },
          "next": "s02_respond_a"
        },
        {
          "id": "C",
          "text": "你不用解释，我大概懂。",
          "label": "[边界感]",
          "affectionDelta": 6,
          "skillUsed": { "id": "boundary", "expGain": 2 },
          "next": "s02_boundary_silence"
        },
        {
          "id": "D",
          "text": "如果一直站居民那边，会不会很难。",
          "affectionDelta": 8,
          "next": "s02_respond_ai"
        },
        {
          "id": "E",
          "text": "不站那边的话，你做这行就没意义了，对吗。",
          "label": "[共情]",
          "affectionDelta": 12,
          "skillUsed": { "id": "empathy", "expGain": 3 },
          "requiredSkill": { "id": "empathy", "level": 1 },
          "next": "s02_respond_empathy_extra"
        }
      ]
    },

    {
      "id": "s02_respond_a",
      "type": "dialogue",
      "speaker": "kai",
      "emotion": "caught",
      "text": "……"
    },
    {
      "id": "s02_respond_a2",
      "type": "dialogue",
      "speaker": "kai",
      "emotion": "distant",
      "text": "居民那边。",
      "next": "s02_respond_a3"
    },
    {
      "id": "s02_respond_a3",
      "type": "dialogue",
      "speaker": "kai",
      "emotion": "neutral",
      "text": "一直都是。",
      "next": "s02_probe_toast"
    },
    {
      "id": "s02_probe_toast",
      "type": "skill_toast",
      "skill": "probe",
      "text": "他没有回避，但也没有让你再问下去。",
      "next": "s02_rain_easing"
    },

    {
      "id": "s02_respond_b",
      "type": "dialogue",
      "speaker": "kai",
      "emotion": "warm",
      "text": "……还好。"
    },
    {
      "id": "s02_respond_b2",
      "type": "dialogue",
      "speaker": "kai",
      "emotion": "neutral",
      "text": "做设计是这样的，有时候。",
      "next": "s02_empathy_moment"
    },
    {
      "id": "s02_empathy_moment",
      "type": "narration",
      "text": "你们各自端起咖啡，没再说话。\n窗外的雨声很细，咖啡馆里只剩下杯沿碰桌的声音。",
      "next": "s02_empathy_toast",
      "image": {
        "path": "assets/cg/ch1/s02_quiet_understanding.png",
        "status": "pending",
        "prompt": "咖啡馆窗边俯视构图，两只白瓷咖啡杯各放在桌面两端，两双手分别托着杯子但视线没有交汇，窗外雨痕，暖色灯光，景深，电影感，留白多",
        "description": "[共情] 选项触发的 CG。表现「没说话也是一种承接」的瞬间。"
      }
    },
    {
      "id": "s02_empathy_toast",
      "type": "skill_toast",
      "skill": "empathy",
      "text": "你接住了他没说出口的那一段。",
      "next": "s02_rain_easing"
    },

    {
      "id": "s02_boundary_silence",
      "type": "dialogue",
      "speaker": "kai",
      "emotion": "neutral",
      "text": "……"
    },
    {
      "id": "s02_boundary_silence2",
      "type": "narration",
      "text": "他没有立刻接话。但你能感觉到他不是在尴尬，是在认真停一停。",
      "next": "s02_boundary_thanks"
    },
    {
      "id": "s02_boundary_thanks",
      "type": "dialogue",
      "speaker": "kai",
      "emotion": "warm",
      "text": "……谢。",
      "next": "s02_boundary_toast"
    },
    {
      "id": "s02_boundary_toast",
      "type": "skill_toast",
      "skill": "boundary",
      "text": "你没有逼他往前走半步，他反而靠近了一点点。",
      "next": "s02_rain_easing"
    },

    {
      "id": "s02_respond_ai",
      "type": "dialogue",
      "speaker": "kai",
      "emotion": "caught",
      "text": "……会。但不站那边，设计就只剩图纸了。",
      "next": "s02_rain_easing"
    },

    {
      "id": "s02_respond_empathy_extra",
      "type": "dialogue",
      "speaker": "kai",
      "emotion": "caught",
      "text": "……"
    },
    {
      "id": "s02_kai_open_a",
      "type": "dialogue",
      "speaker": "kai",
      "emotion": "warm",
      "text": "……是。"
    },
    {
      "id": "s02_kai_open_a2",
      "type": "dialogue",
      "speaker": "kai",
      "emotion": "neutral",
      "text": "我做设计的第一年，画过一个商场。甲方很满意，业主也满意。三年之后我去看，里面没有一处给小孩坐下来的地方。"
    },
    {
      "id": "s02_kai_open_a3",
      "type": "dialogue",
      "speaker": "kai",
      "emotion": "distant",
      "text": "从那以后我就知道，图纸上看着合理的事，落到地上不一定。",
      "next": "s02_kai_open_a_toast"
    },
    {
      "id": "s02_kai_open_a_toast",
      "type": "skill_toast",
      "skill": "empathy",
      "text": "你听见了他平时不会讲的那段。",
      "next": "s02_rain_easing"
    },

    {
      "id": "s02_rain_easing",
      "type": "narration",
      "text": "窗外的雨渐渐小了，但还没停。\n天已经开始暗下来，咖啡馆里亮起了灯。",
      "next": "s02_kai_remember"
    },

    {
      "id": "s02_kai_remember",
      "type": "dialogue",
      "speaker": "kai",
      "emotion": "neutral",
      "text": "……上次见面，你说你不喜欢太吵的地方。"
    },
    {
      "id": "s02_kai_remember2",
      "type": "narration",
      "text": "你愣了一下。\n那是在朋友的聚会上，你随口说的一句话。你自己都不记得了。",
      "next": "s02_kai_remember3"
    },
    {
      "id": "s02_kai_remember3",
      "type": "dialogue",
      "speaker": "kai",
      "emotion": "neutral",
      "text": "……所以找了这里。",
      "next": "s02_player_realize"
    },

    {
      "id": "s02_player_realize",
      "type": "choice",
      "prompt": null,
      "affectionNote": "这是第一章情感浓度最高的节点。凯恒承认他为了她选了这家咖啡馆——哪怕他不会承认这件事的意义。",
      "options": [
        {
          "id": "A",
          "text": "……你记得那句话。",
          "affectionDelta": 12,
          "next": "s02_realize_a"
        },
        {
          "id": "B",
          "text": "所以这不是偶遇。",
          "affectionDelta": 10,
          "next": "s02_realize_b"
        },
        {
          "id": "C",
          "text": "我不知道该高兴，还是该装作没听懂。",
          "affectionDelta": 12,
          "next": "s02_realize_ai"
        }
      ]
    },

    {
      "id": "s02_realize_a",
      "type": "dialogue",
      "speaker": "kai",
      "emotion": "caught",
      "text": "……"
    },
    {
      "id": "s02_realize_a2",
      "type": "dialogue",
      "speaker": "kai",
      "emotion": "neutral",
      "text": "记得。",
      "next": "s02_end_transition"
    },

    {
      "id": "s02_realize_b",
      "type": "dialogue",
      "speaker": "kai",
      "emotion": "caught",
      "text": "……偶遇。"
    },
    {
      "id": "s02_realize_b2",
      "type": "dialogue",
      "speaker": "kai",
      "emotion": "neutral",
      "text": "算是。",
      "next": "s02_end_transition"
    },

    {
      "id": "s02_realize_ai",
      "type": "dialogue",
      "speaker": "kai",
      "emotion": "warm",
      "text": "……不用装。听懂就行。",
      "next": "s02_end_transition"
    },

    {
      "id": "s02_end_transition",
      "type": "narration",
      "text": "雨停了。\n你们同时看向窗外，地面是湿的，空气里有泥土和凉意。",
      "next": "ch1_scene03"
    }
  ]
}
