    },

    {
      "id": "s03_boundary_react",
      "type": "dialogue",
      "speaker": "kai",
      "emotion": "neutral",
      "text": "……嗯。"
    },
    {
      "id": "s03_boundary_react2",
      "type": "skill_toast",
      "skill": "boundary",
      "text": "你没有把话说满。他记住了这一点。",
      "next": "s03_branch_affection"
    },

    {
      "id": "s03_default_react",
      "type": "dialogue",
      "speaker": "kai",
      "emotion": "neutral",
      "text": "……走吧。",
      "next": "s03_branch_affection"
